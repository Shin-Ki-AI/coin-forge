# Coin Forge 환경변수 템플릿 — 복사해서 .env 로 사용 (.env 는 커밋 금지)

# --- Upbit (주문·잔고) ---
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# --- UpbitBridge (캔들 수집) ---
UPBIT_BRIDGE_WS_URL=ws://localhost:8080/ws
CANDLE_COUNT=240

# --- MongoDB ---
MONGO_URI=mongodb://mongo:27017/coinforge

# --- Notifications ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=

# --- Trading ---
MARKET=KRW-BTC
TRADING_MODE=paper          # paper | live
TOTAL_EQUITY_KRW=1000000    # paper 모드 초기 자본
SLIPPAGE_BP=5               # paper/백테스트 시장가 슬리피지(bp). live 는 실체결가 사용
SCHEDULER_BUFFER_SECONDS=10 # 봉 마감 후 대기 초 (완성봉은 타임스탬프로 선택)
ORDER_TYPE=market           # live 주문 유형: market | limit (limit 은 미체결 시 시장가 폴백)

# --- Risk ---
RISK_PER_TRADE_PCT=0.01
DAILY_LOSS_LIMIT_PCT=0.03
HARD_STOP_PCT=0.03
