# Coin Forge 환경변수 템플릿 — 복사해서 .env 로 사용 (.env 는 커밋 금지)

# --- Upbit (주문·잔고) ---
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# --- UpbitBridge (캔들 수집) ---
UPBIT_BRIDGE_WS_URL=ws://localhost:8080/ws
CANDLE_COUNT=240

# --- MongoDB ---
MONGO_URI=mongodb://mongo:27017/coinforge

# --- Notifications ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=

# --- Trading ---
MARKET=KRW-BTC
TRADING_MODE=paper          # paper | live
TOTAL_EQUITY_KRW=1000000    # paper 모드 초기 자본
SLIPPAGE_BP=5               # paper/백테스트 시장가 슬리피지(bp). live 는 실체결가 사용
SCHEDULER_BUFFER_SECONDS=10 # 봉 마감 후 대기 초 (완성봉은 타임스탬프로 선택)
ORDER_TYPE=market           # live 주문 유형: market | limit (limit 은 미체결 시 시장가 폴백)

# --- Risk ---
RISK_PER_TRADE_PCT=0.01
DAILY_LOSS_LIMIT_PCT=0.03
HARD_STOP_PCT=0.03

# --- 비중조절 / 포지션 사이징 (#3) ---
SIZING_MODE=risk            # risk(1% 룰) | fixed(고정 비율)
MAX_POSITION_PCT=0.30       # 1회 주문금액 상한 = 자본의 30% (100% 올인 방지, 1.0=상한없음)
FIXED_POSITION_PCT=0.20     # fixed 모드에서 자본 대비 주문금액 비율

# --- 전략/보조기법 (실거래·모의투자에 적용, 기본 off) ---
# 이평선 기간·관문 토글 (대시보드 '기법 비교'로 최적값 탐색 후 여기에 반영)
# MA_SHORT=20 / MA_MID=60 / MA_LONG=200
# REQUIRE_CLOUD=true / REQUIRE_MA_ALIGNMENT=true / REQUIRE_PULLBACK=true / REQUIRE_VOLUME=false
REQUIRE_RSI=false           # RSI 과매수 시 진입 보류
RSI_OVERBOUGHT=70           # RSI 과매수 기준
REQUIRE_MACD=false          # MACD < 시그널(약세) 시 진입 보류
